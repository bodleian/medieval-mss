               <msContents>

                  <summary source="#allegro">Fragment of Spell 125 ("The Negative Confession") from
                     the Book of the Dead</summary>
                  <textLang mainLang="egy-Egyp" source="#TM">Egyptian Hieroglyphic</textLang>

               </msContents>
               <physDesc>
                  <p>Written along the fibres, the papyrus is mounted on cardboard and back is not
                     visible.</p>
                  <objectDesc form="scroll">
                     <supportDesc material="papyrus">
                        <support>papyrus</support>
                        <extent>One fragment of papyrus.<dimensions type="scroll" unit="mm">
                              <height>129</height>
                              <width>176</width>
                           </dimensions></extent>
                     </supportDesc>
                     <layoutDesc>
                        <layout>Eleven incomplete columns written in "Book of the Dead cursive"
                           hieroglyphs.</layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote>Written by one scribe, mostly in black ink, with some red ink at the
                        start of each column</handNote>
                  </handDesc>
