               <head>Three pieces of linen used to cover a mummy.</head>
               <msContents>
                  <summary> Three pieces of linen taken from mummy wrappings, possibly from the same
                     mummy, only one is inscribed on both sides with a Hieratic inscription. </summary>

                  <textLang mainLang="egy-Egyh">Ancient Egyptian in Hieratic script.</textLang>
               </msContents>
               <physDesc>
                  <objectDesc form="other">
                     <supportDesc material="linen">
                        <support>linen</support>
                        
                     </supportDesc>

                  </objectDesc>



               </physDesc>
               <history>
                  <origin>
                     <p>
                        <origDate calendar="Gregorian" notBefore="-0332" notAfter="-0030">
                           Ptolemaic Period, c. 332–30 BCE
                        </origDate>
                     </p>
                  </origin>
                  <provenance>Possibly from <ref type="place_7001297">Thebes</ref>. Purchased by
                     Colonel Valentine Patrick Terrell Vivian in Egypt around 1882 and bequeathed to
                     his brother-in-law the Reverend Vivian Eccles Skrine. </provenance>
                  <acquisition>Given to the Bodleian by the Reverend Vivian Eccles Skrine
                     (1850-1925), 30 March 1913.</acquisition>
               </history>
