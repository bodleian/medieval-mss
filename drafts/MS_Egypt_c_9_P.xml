               <msContents>
                  <summary>Fragment of an abridged version of Opening of the Mouth for Breathing for
                     a man called Komoapis. The other part of this papyrus is now Paris, Louvre E
                     10605.</summary>
                  <textLang mainLang="egy-Egyd" source="#TM">Egyptian in Demotic script</textLang>

               </msContents>
               <physDesc>
                  <objectDesc form="sheet">
                     <supportDesc material="papyrus">
                        <support>papyrus</support>
                        <extent>One fragment of papyrus. <dimensions type="leaf" unit="mm">
                              <height>101</height>
                              <width>334</width>
                           </dimensions></extent>
                     </supportDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote>Likely written by one scribe, all in black ink.</handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote>No vignette accompanies the text on this fragment.</decoNote>
                  </decoDesc>


