               <msContents>

                  <summary>Fragments of the Book of the Dead written for the 'chantress of Amun
                     Djed-Khons-ius-ankh' with remnants of Spells 166 and 22-23.</summary>
                  <textLang mainLang="egy-Egyh" source="#TM">Egyptian in Hieratic script.</textLang>

               </msContents>
               <physDesc>
                  <objectDesc form="scroll">
                     <supportDesc material="papyrus">
                        <support>papyrus</support>
                        <extent>Five fragments of papyrus. The dimensions given are for the largest and
                           smallest fragments respectively.<dimensions type="leaf" unit="mm">
                              <height>218</height>
                              <width>125</width>
                           </dimensions><dimensions type="leaf" unit="mm">
                              <height>65</height>
                              <width>15</width>
                           </dimensions></extent>
                     </supportDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote>Likely written by one scribe, all in black ink</handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote>No vignette accompanies the text on these fragments.</decoNote>
                  </decoDesc>



               </physDesc>
