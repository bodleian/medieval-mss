               <msContents>

                  <summary source="#allegro">Lamentations of Isis and Nephthys over Osiris</summary>
                  <textLang mainLang="egy-Egyh" source="#TM">Egyptian in Hieratic script</textLang>

               </msContents>
               <physDesc>
                
                  <objectDesc>
                     <supportDesc material="papyrus">
                        <support>papyrus</support>
                        <extent>Fragment of the central portion of a much larger papyrus scroll
                           other parts of which are now at the British Museum in London and the
                           World Museum in Liverpool.<dimensions type="scroll" unit="mm">
                              <height>235</height>
                              <width>159</width>
                           </dimensions></extent>
                     </supportDesc>
                     <layoutDesc>
                        <layout>Written along the fibres in one column of 26 lines. The papyrus is mounted in a
                           glass frame, and its back is currently not visible. There are lacunas in most
                           of the lines which were later filled with fragments taken from other parts of
                           the original scroll which cannot be joined any more.</layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote>Written by one scribe. Mostly in black ink, with rubric in red
                        ink.</handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote>No vignette accompanies the text on these fragments.</decoNote>
                  </decoDesc>


               </physDesc>
