               <msContents>
                  <summary>A fragment of spells 136B to 149 of the Book of the Dead, with
                     translation</summary>
                  <textLang mainLang="egy-Egyp" source="#TM">Egyptian Hieroglyphic</textLang>

               </msContents>
               <physDesc>
                  <p>The papyrus is mounted on paper and, accompanied by a full transcription and
                     translaton, was bound as a small booklet.</p>
                  <objectDesc form="sheet">
                     <supportDesc material="papyrus">
                        <support>papyrus</support>
                        <extent>One fragment of papyrus. <dimensions type="leaf" unit="mm">
                              <height>75</height>
                              <width>75</width>
                           </dimensions></extent>
                     </supportDesc>
                     <layoutDesc>
                        <layout>Six vertical registers of hieroglyphs.</layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote>Likely written by one scribe, all in black ink in "Book of the Dead cursive".</handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote>No vignette accompanies the text.</decoNote>
                  </decoDesc>

               </physDesc>
