               <head>Poor Caitiff, etc.; England, 15th century, first half</head>
               <msContents>
                  <textLang mainLang="enm">Middle English</textLang>
                  <msItem class="#theologica" n="1" xml:id="MS_Lyell_29-item1">
                     <title key="work_13918">Poor Caitiff</title>
                   
                     <msItem n="a">
                        <locus> (fol. 1)</locus>
                        <note> Prologue </note>
                        <incipit>This tretijs compiled of a pore caitif</incipit>
                     </msItem>
                     <msItem n="b">
                        <locus> (fol. 1v)</locus>
                        <rubric>Oure bileeve</rubric>
                        <incipit>The ground of al goodnesse</incipit>
                     </msItem>
                     <msItem n="c">
                        <locus> (fol. 12)</locus>
                        <rubric> A prolog <add>on þe ten heestis</add> [added by hand b]</rubric>
                        <incipit>A man axide of Crist</incipit>
                     </msItem>
                     <msItem n="d">
                        <locus> (fol. 46v)</locus>
                        <rubric>Þe prolog on þe pater noster</rubric>
                        <incipit>Crist seiþ, who þat lovyþ hym</incipit>
                     </msItem>
                     <msItem n="e">
                        <locus> (fol. 58v)</locus>
                        <rubric>Of parfiȝt lijf</rubric>
                        <incipit>Crist not compellyng but freli counseilyng</incipit>
                     </msItem>
                     <msItem n="f">
                        <locus>(fol. 61v)</locus>
                        <rubric>Of meke suffrynge</rubric>
                        <incipit>But who þat is verreili fed </incipit>
                     </msItem>
                     <msItem n="g">
                        <locus>(fol. 63v) </locus>
                        <incipit>Whanne þou art temptid eþir troublid</incipit>
                     </msItem>
                     <msItem n="h">
                        <locus>(fol. 64r)</locus>
                        <rubric>Of þe hevenli chartre</rubric>
                        <incipit>Everi wijs man þat cleymyþ his eritage</incipit>
                     </msItem>
                     <msItem n="j">
                        <locus> (fol. 69r) </locus>
                        <rubric>Of governaunce of þe hors</rubric>
                        <incipit>Almyȝti god seip bi holi Ioob</incipit>
                     </msItem>
                     <msItem n="k">
                        <locus>(fol. 74v) </locus>
                        <rubric>To seke Ihesu</rubric>
                        <incipit>Who so ever þou be þat araiest þee</incipit>
                     </msItem>
                     <msItem n="l">
                        <locus>(fol. 76v)</locus>
                        <rubric>Of þre degrees of love</rubric>
                        <incipit>O onlich lord be to me teeris of love</incipit>
                     </msItem>
                     <msItem n="m">
                        <locus> (fol. 79v)</locus>
                        <rubric>Of mekenesse and love</rubric>
                        <incipit>To ony degree of verrei love</incipit>
                     </msItem>
                     <msItem n="n">
                        <locus>(fol. 81r)</locus>
                        <rubric> Of iust will and uniust</rubric>
                        <incipit>Everi deed preisable eþir reprevable</incipit>
                     </msItem>
                     <msItem n="o">
                        <locus> (fol. 82r)</locus>
                        <rubric>Of contemplatijf lijf and actijf lijff</rubric>
                        <incipit>Crist lovyde myche Marie and Martha</incipit>
                     </msItem>
                     <msItem n="p">
                        <locus>(fol. 84r)</locus>
                        <rubric> Þe prolog <note>(to the piece sometimes called 'Of Chastity' or 'The mirror
                              of maidens') </note></rubric>
                        <incipit>I write þis tretijs in .v. schort chapitris</incipit>
                        <explicit><locus>(fol. 94v)</locus> in endeles blesse. Amen.</explicit>
                        <note> A leaf is missing after fol. 47. The pieces are in the same order,
                           though with some different headings, in MS. Ashmole 1286, 15th cent., fol.
                           32-108. Most of item g is pr. J. Bazire and E. Colledge in notes to
                           <title>The Chastising of God's Children</title>, Oxford, 1957, p. 262,
                           and the first part of item h is pr. M. C. Spalding in appendix to <title>The
                              Middle English Charters of Christ</title>, Bryn Mawr, 1914, pp. 100-2.
                        </note>
                     </msItem>
                  </msItem>
                  
                  <msItem n="2">
                     <locus>(fols. 94r-99r)</locus>
                     <title key="work_3943">The Mirror of Sinners</title>
                     <rubric>Here bigynneþ þe myrrour of synneris</rubric>
                     <incipit>For þat we ben in þe weie of his failinge lijf</incipit>
                     <explicit>þat bouȝte us wiþ his prescious bloode. Amen. </explicit>
                     <note>Pr. C. Horstmann, <title>Yorkshire Writers. Richard Rolle of Hampole and his
                           followers</title> II, 1896, pp. 436-40. See also Wells,
                        <title>Manual</title> cit., p. 458 (ch. xi § 43). </note>
                  </msItem>
                  <msItem n="3">
                     <locus>(fols. 99v-106r)</locus>
                     <note>Further short pieces </note>
                     <msItem n="3a">
                        <locus>(fol. 99v)</locus>
                        <note> on the seven deadly sins, headed 'Pride'</note>
                        <incipit>The sevene deedli synnes. Pride, wraþþe and envie synnes of þe fend.
                           These be þe large weie to helle ... Whanne is a man proude? . aȝens goddis
                           will. And so of þis first synne comeþ veyn glorie</incipit>
                        <explicit><locus>(fol. 102r)</locus> þat þou myȝte do to Ihesu Crist. </explicit>
                        <note>Cf. MS. Tanner 201, fol. 1. Our MS. is much fuller. </note>
                     </msItem>
                     <msItem n="3b">
                        <note>On the wits</note>
                        <incipit><locus>(fol. 102r)</locus> Here bigynnen þe .v. wittis of þe bodi.
                           heeryng. seyng. smelling. tastinge and feelinge. No þing makiþ men sunner to
                           falle fro þe comaundementis of god þan doiþ entring of þe fende at
                           þese</incipit>
                        <explicit>unclenenesse lustily</explicit>
                        <incipit>The .v. wittis of þe soule. will. mynde. undirstondinge. ymaginacion
                           and resoun. First wille þou þat þe will of god be fulfilled bifor þin owne
                           wille</incipit>
                        <explicit><locus>(fol. 102v)</locus>wracke and myscheeff</explicit>
                     </msItem>
                     <msItem n="3c">
                        <rubric>Here ben þe fyve wittis</rubric>
                        <incipit>Friste kepe well þin herte and it is esy to kepe alle þi
                           wittis</incipit>
                        <explicit><locus>(fol. 104r)</locus> and ocupie þee in goddis servyce Amen
                        </explicit>
                     </msItem>
                     <msItem n="3d">
                        <rubric> Here ben þe seven werkes of merci bodili and gostli</rubric>
                        <incipit>Alle maner of men ben holden bi goddis lawe</incipit>
                        <explicit><locus>(fol. 106r)</locus> it schal brynge us to hevene wiþ outen
                           ende. God brynge us þedir Amen. </explicit>
                        <note>The rest of fol. 106r and fol. 106v-108bv was originally blank.</note>
                     </msItem>
                  </msItem>
               </msContents>
