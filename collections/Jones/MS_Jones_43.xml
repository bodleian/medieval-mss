               <physDesc>
                  <p n="composite">Composite: fols. 1–30 are a mid-15th-century English supplement
                     to fols. 31–111, an early-fifteenth-century Flemish (?) Book of Hours for the
                     English market.</p>
                  <objectDesc>
                     <supportDesc>
                        <extent resp="#VD"><seg type="leaf"><measure type="endleaf" quantity="3"
                                 >3</measure> + <measure type="leaf" quantity="108">108
                                    (105)</measure> + <measure type="endleaf" quantity="3"
                                       >3</measure></seg> fol. <dimensions type="leaf" unit="mm">
                                          <height>171</height>
                                          <width>123</width>
                                       </dimensions>
                           <dimensions type="written" unit="mm">
                              <height min="108" max="110">108/110</height>
                              <width min="65" max="67">65/67</width>
                           </dimensions>
                        </extent><condition> Two leaves missing after fol.3, 36, 57, 74, and 84; one leaf
                           after fol.12, 30, 50, 51, and 54</condition>
                     </supportDesc>
                     <layoutDesc resp="#VD">
                        <layout columns="1" writtenLines="23">23 long lines.</layout>
                     </layoutDesc>
                        
                  </objectDesc>
                  <bindingDesc>
                     <binding contemporary="true">
                        <p>Original (?) binding, sheepskin on boards.</p>
                     </binding>
                  </bindingDesc>
                  
