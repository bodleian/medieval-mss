               <msContents>
                 
                  <msItem  xml:id="MS_Jones_46-item1"><locus from="1r" to="116v" type="inferred"/>
                     <title key="work_10579">Book of Hours, Use of Sarum</title>
                     <msItem >
                        <locus>(fol. 2)</locus>
                        <note>Sarum-Norwich kalendar. Dedication of Norwich cathedral is on 24 September.</note>
                     </msItem>
                     <msItem >
                        <locus>(fol. 8)</locus>
                        <note>Office of the Virgin with the Hours of the Cross (fol. 28v) and Our Lady’s Compassion (fol. 29: Matris cor virgineum) worked in</note>
                     </msItem>
                     <msItem >
                        <locus>(fol. 47v)</locus>
                        <note>Joys of the Virgin and prayer (fol. 49: Domine J.C. qui hanc)</note>
                     </msItem>
                     <msItem >
                        <locus>(fol. 50)</locus>
                        <note>Penitential Psalms with litany (fol. 60)</note>
                     </msItem>
                     <msItem >
                        <locus>(fol. 69)</locus>
                        <note>Office of the dead, and commendation (fol. 94v), the psalm 118 with the monastic divisions</note>
                     </msItem>
                     <msItem >
                        <locus>(fol. 108)</locus>
                        <note>Added prayers of the latter part of the 15th cent among which a commemoration of St Henry VI, king (fol. 117: Rex Henricus sit amicus).</note>
                     </msItem>
                     <textLang mainLang="la">Latin</textLang>
                  </msItem>
                  <msItem>
                     <locus>(fol. 118v)</locus>
                     <incipit>Euery day wen <unclear>she</unclear> say may say v pater nosters &amp; v aves for here 
                       fatheres soll &amp; all Crystyn solles</incipit>
                     <note>Added note (s. xv/xvi), given in full.</note>
                     <textLang mainLang="enm">Middle English</textLang>
                  </msItem>
               </msContents>
