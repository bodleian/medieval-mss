               <msContents> <textLang mainLang="la">Latin</textLang>
                  
                  <msItem n="1" xml:id="MS_Selden_Supra_76-item-1">
                     <locus from="3">(fol. 3)</locus>
                     <author key="person_39784406">Roger of Hereford</author>
                     <title key="work_4457">De iudiciis astronomiae liber I</title>
                     <rubric>Liber magistri Rogeri Hereford de iudiciis astronomicis</rubric>
                     <incipit>Quoniam regulas artis</incipit>
                     <note>Some leaves are wanting after fol. 5: at fol. 7 is a note on making almanacs, etc.</note>
                  </msItem>
                  <msItem n="2" xml:id="MS_Selden_Supra_76-item-2">
                     <locus from="10v">(fol. 10v)</locus>
                     <author key="person_39784406">Roger of Hereford</author>
                     <title key="work_4457">De iudiciis astronomiae liber II</title>
                     <rubric>Liber de tribus generalibus iudiciis astronomie ex quibus cetera omnia defluunt, editus a magistro Rogero Hereford</rubric>
                     <incipit>Quoniam circa tria fit omnis astronomica considerado</incipit>
                     <note>In three sections with prologue: at fol. 19v is a note adapted to the latitude of Hereford.</note>
                  </msItem>
                  <msItem n="3" xml:id="MS_Selden_Supra_76-item-3">
                     <locus from="20">(fol. 20)</locus>
                     <title key="work_7536">Liber de motibus planetarum</title>
                     <rubric>Liber de motibus planetarum</rubric>
                     <incipit>Inuestigantibus astronomie raciones</incipit>
                     <listBibl><bibl>C. Philipp E. Nothaft, ‘Ptolemaic Orbs in Twelfth-Century England: A Study and Edition of the Anonymous Liber de Motibus Planetarum’, <title>Mediterranea. International Journal on the Transfer of Knowledge</title>, 31 March 2018, pp. 145–210, doi:10.21071/mijtk.v0i3.10774 (his manuscript S, pp. 174-5)
                     </bibl></listBibl>
                  </msItem>
                  <msItem n="4" xml:id="MS_Selden_Supra_76-item-4">
                     <locus from="31">(fol. 31)</locus>
                     <title key="work_10409" type="desc">Astronomy</title>
                     <rubric>Doctrina equacionis omnium planetarum</rubric>
                     <incipit>Primo sumantur anni collecti</incipit>
                     <note>Identified in Ptolomaeus Arabus et Latinus as "canons of astronomical tables and astrolabe chapters, including  Pseudo-Ptolemy, Liber de compositione universalis astrolabii, preface only.</note>
                  </msItem>
                  <msItem n="5" xml:id="MS_Selden_Supra_76-item-5">
                     <locus from="41">(fol. 41)</locus>
                     <rubric>Liber de institucione vniuersitatis</rubric>
                     <incipit>Omnis homo naturaliter desiderat</incipit>
                     <note>On the proper principles of an organized society or state: two leaves are lost after fol. 42.</note>
                  </msItem>
                  <msItem n="6" xml:id="MS_Selden_Supra_76-item-6">
                     <locus from="47">(fol. 47)</locus>
                     <author key="person_90634457">Alkindi </author>
                     <title key="work_440">De radiis stellarum</title>
                     <rubric>Theoreica [sic] arcium magicarum</rubric>
                     <incipit>Omnes homines qui sensibilia</incipit>
                  </msItem>
                  <msItem n="7" xml:id="MS_Selden_Supra_76-item-7">
                     <locus from="61">(fol. 61)</locus>
                     <rubric>Liber graduum</rubric>
                     <note>Gradus being defined on fol. 64v as 'intencio primordialis alicuius proprietatis [sc. caliditatis etc.] ... ultra suum contrarium in dupla [etc.] ... proporcione'.</note>
                  </msItem>
                  <msItem n="8" xml:id="MS_Selden_Supra_76-item-8">
                     <locus from="69v">(fol. 69v)</locus>
                     <rubric>Liber de uulgari iudicio sermonis</rubric>
                     <incipit>Quoniam plurimi hominum uulgari rerum intellectu</incipit>
                     <note>A treatise on the value of assertion.</note>
                  </msItem>
                  <msItem n="9" xml:id="MS_Selden_Supra_76-item-9">
                     <locus from="74">(fol. 74)</locus>
                     <title type="desc" key="work_10154" >Alchemical recipes</title>
                     <incipit>Scorpium recentem confractum in alcara, scilicet in fornace</incipit>
                  </msItem>
                  <msItem n="10" xml:id="MS_Selden_Supra_76-item-10">
                     <locus from="109v">(fol. 109v)</locus>
                     <author key="person_2017">'Thetel'</author>
                     <title key="work_205">Liber sigillorum</title>
                     <incipit>In nomine Domini hic est liber preciosus magnus atque sacratus siggillorum coelez quem fecerunt filii Israel in deserto secundum motus &amp; cursus siderum</incipit>
                     <note>On foll. 113v-115 are some half-erased notes.</note>
                     <listBibl><bibl>Ockenström, Lauri, and Vajra Regan, ‘The Hermetic Origins of the Liber Sigillorum of Techel’, <title>The Journal of Medieval Latin</title>, 33.1 (2023), pp. 173–266, doi:10.1484/J.JML.5.133617, at pp. 202-3, identifies this as a compilation containing: 'Techel B', Azareus (?), "abbreviations of Damigeron-Evax, and 11–12 badly corrupted chapters from Techel
                           A"</bibl></listBibl>
                  </msItem>
                  <msItem n="11" xml:id="MS_Selden_Supra_76-item-11">
                     <locus from="116">(fol. 116)</locus>
                     <title key="work_10154" type="desc">Alchemy</title>
                     <incipit>Michi uidetur dicere quod annussadir dum subleuatur aceto semper adequetur</incipit>
                    
                  </msItem>
                  
