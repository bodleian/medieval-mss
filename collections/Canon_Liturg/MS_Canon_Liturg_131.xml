               <history>
                  <origin>
                     <origDate calendar="Gregorian" notAfter="1500" notBefore="1490">15th century, end</origDate>
                     <origPlace cert="low">
                        <country key="place_1000080">Italy</country>, <settlement key="place_7003085">Padua (?)</settlement> (?)<!--ORIGINAL: Italian, Ferrara (?)--></origPlace>
                  </origin>
                  
                  <provenance> On the title-page (<ref target="https://digital.bodleian.ox.ac.uk/objects/b7083d8d-7ee8-4eef-8338-3a83cf239dc7/surfaces/60b2ba9f-a705-4863-b19d-17accec77aa7/">fol. 14</ref>) are the arms of the Strozzi of 
                     Ferrara: Quarterly; 1 and 4: or on a fess gules three crescents; 2 and 3: azure two fleurs-de-lys argent 
                     between the 3 points of a label gules</provenance>
                  
                  <provenance>St Maurelius (May 7) of Imola and St Domninus ('Doninus', 9th October) of Parma (?) are in the Calendar</provenance>
                  
                  <provenance>At the beginning, a 16th-century addition: 'copia d’oratione francese e tradotta in lingua italiana trovata nel padiglione di Carlo viii Re di Francia 
                     in tempo de battaglia sequita al Taro l’anno 1495...'</provenance>
                  
                  <provenance><persName key="person_2384880" role="fmo">Matteo Luigi Canonici (1727– <hi rend="italic">c</hi>. 1806)</persName></provenance>
                  <provenance notAfter="1807" resp="#SC">Following Canonici's death, the collection passed to his brother, <persName key="person_446" role="fmo">Giuseppe Canonici</persName>, and 
                     then to Canonici's nephew, <persName role="fmo" key="person_431">Giovanni Perissinotti</persName>, in 1807 following Giuseppe Canonici's death</provenance>
                  <acquisition when="1817">Bought by the Bodleian Library in 1817 from Giovanni Perissinotti. On the purchase, see <ref target="https://digital.bodleian.ox.ac.uk/collections/canonici/">Digital Bodleian</ref></acquisition>
                  
