                        <locus>(fol. 14r)</locus>
                        <title type="desc">Office of the Virgin</title>
                        <rubric>Incipit offitium beate u<ex>ir</ex>ginis marie <sic>secumdum</sic> ordinem curie romane</rubric>
                        <incipit>Domine labia mea aperies</incipit>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 94r)</locus>
                        <title type="desc">Office of the Dead</title>
                        <rubric>Incipit officium mortuorum</rubric>
                        <incipit>Dilexi quoniam exaudiet d<ex>omi</ex>n<ex>u</ex>s uocem or<ex>atio</ex>nis mee</incipit>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 142r)</locus>
                        <title type="desc">Penitential Psalms</title>
                        <rubric>Incipit septem psalmi penitentiales</rubric>
