                  <msItem class="#liturgica" n="1" xml:id="MS_Canon_Liturg_208-item1"><locus from="1r" to="494v" type="inferred"/>
                     <title key="work_10656" type="desc">Breviary, Use of Rome (Franciscan)</title>
                     <rubric>Ordo breuiarii Fratrum Minorum secundum consuetudinem Romane Curie</rubric>
                     <colophon>Qui scripsit scribat semper cum domino vivat. Dominus conservet eum et vivificet eum et beatum faciat eum in terra etc. (fol. 469v)</colophon>
                     
                     <msItem>
                        <locus>(fol. 1)</locus>
