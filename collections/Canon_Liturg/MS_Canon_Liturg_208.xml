                        <locus>(fol. 87)</locus>
                        <title type="desc">Hymnal</title>
                        <note>Imperfect at the end</note>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 99v)</locus>
                        <title type="desc">Litany of the Saints</title>
                        <note>Preceded by a few canticles on what is probably the last leaf of the original psalter
                        </note>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 101v)</locus>
                        <title type="desc">Additional tables for the responsories of September</title>
