               <history>
                  <origin>
                     <origDate calendar="Gregorian" when="1430" cert="high">1430 (?)</origDate>
                     <origPlace>
                        <country key="place_1000080">Italy</country>, <settlement key="place_7018159">Venice</settlement>
                        <!--ORIGINAL: Italian, Venice-->
                     </origPlace>
                  </origin>
                  
                  <provenance>Fol. 8r: Easter tables end 'Anno domini 1430. epacta 6. aureus numerus 6. littera dominicalis .a.'</provenance>
                  
                  <provenance resp="#PA">Despite the Calendar tables, the decoration suggests a date as late as the third quarter of the 15th century</provenance>
                  
                  <provenance>Fol. 9r: 'Sancti Georgii' and '47' (erased) in a contemporary hand, referring to the Benedictine <orgName key="org_266324378">Congregation of S. Giustina of Padua</orgName> at 
                     S. Giorgio Maggiore, Venice. </provenance>
                  
                  <provenance resp="#PA">Calendar and tables imply 1430, but </provenance>
                  
                  
                  <provenance><persName key="person_2384880" role="fmo">Matteo Luigi Canonici (1727– <hi rend="italic">c</hi>. 1806)</persName></provenance>
                  <provenance notAfter="1807" resp="#SC">Following Canonici's death, the collection passed to his brother, <persName key="person_446" role="fmo">Giuseppe Canonici</persName>, and 
                     then to Canonici's nephew, <persName role="fmo" key="person_431">Giovanni Perissinotti</persName>, in 1807 following Giuseppe Canonici's death</provenance>
                  <acquisition when="1817">Bought by the Bodleian Library in 1817 from Giovanni Perissinotti. On the purchase, see <ref target="https://digital.bodleian.ox.ac.uk/collections/canonici/">Digital Bodleian</ref></acquisition>
                  
               </history>
