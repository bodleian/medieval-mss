               <history>
                  <origin>
                     <origDate calendar="Gregorian" notAfter="1430" notBefore="1420"><hi rend="italic">c</hi>. 1420–1430</origDate>
                     <origPlace cert="low">
                        <country key="place_7006470">Bohemia</country> (?), in or near <settlement key="place_7006464">Prague</settlement></origPlace>
                  </origin>
                  
                  <provenance>Among the names in the Litany are Stanislaus, Wenceslaus, Florian and Ludmilla ('Bohemorum patrona', fol. 330v), suggesting 
                     a connection with Bohemia</provenance>
                  
                  <provenance>The date is fixed to within a few years by calendarial notes on fols 379-381, cf. a <foreign xml:lang="gmh">German</foreign> rubric on fol. 381v ('Die tauell czayget wie uil 
                     man scoll abcziehen vber M CCCC  XXXV iar nach Christi gepurd, &amp;c.').</provenance>
                  
                  <provenance><persName key="person_2384880" role="fmo">Matteo Luigi Canonici (1727– <hi rend="italic">c</hi>. 1806)</persName></provenance>
                  <provenance notAfter="1807" resp="#SC">Following Canonici's death, the collection passed to his brother, <persName key="person_446" role="fmo">Giuseppe Canonici</persName>, and 
                     then to Canonici's nephew, <persName role="fmo" key="person_431">Giovanni Perissinotti</persName>, in 1807 following Giuseppe Canonici's death</provenance>
                  <acquisition when="1817">Bought by the Bodleian Library in 1817 from Giovanni Perissinotti. On the purchase, see <ref target="https://digital.bodleian.ox.ac.uk/collections/canonici/">Digital Bodleian</ref></acquisition>
                  
               </history>
