               <msContents>
                  
                  <msItem class="#liturgica" n="1" xml:id="MS_Canon_Liturg_76-item1">
                     <title key="work_10561" type="desc">Book of Hours, Use of Rome</title>
                     
                     <msItem>
                        <note>Added by a North Italian scribe of the 15th century with the signature <persName role="scr">'F.T.'</persName> on fol. 4v:</note>
                        
                        <!-- Add authority record -->                  
                     
                     <msItem>
                        <locus>(fol. 3v)</locus>
                        <title type="desc">
                           Sequence of St Mary Magdalen
                        </title>
                        <incipit>Salve felix Magdalena</incipit>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 5)</locus>
                        <title type="desc" xml:lang="la">O domine I.C. adoro te</title>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 5v)</locus>
                        <title type="desc">
                           Pericope from St Mark’s gospel
                        </title>
                        <incipit>Maria Magdalene et Maria Jacobi</incipit>
                     </msItem>
                        
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 6)</locus>
                        <title type="desc">Calendar</title>
                        <note>With a saint for every day</note>
                        <textLang mainLang="frm">Middle French</textLang>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 18)</locus>
                        <title type="desc">Pericopes from the Gospels</title>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 23)</locus>
                        <title type="desc" xml:lang="la">Obsecro te</title>
                     </msItem>
                     
                     
                     <msItem>
                        <note>Added by a North Italian scribe of the 15th century:</note>
                        <msItem>
                        <locus>(fol. 27)</locus>
                        <title type="desc">Mass of the Virgin according to the Carthusian use</title>
                        <rubric>Missa beate Virginis Marie secundum ordinem Cartusiensem</rubric>
                     </msItem>
                  </msItem>
                     
                     <msItem>
                        <locus>(fol. 30)</locus>
                        <title type="desc">Office of the Virgin</title>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 98)</locus>
                        <title type="desc">Office of the Cross</title>
                        <rubric>de Cruce</rubric>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 102)</locus>
                        <title type="desc">Office of the Holy Ghost</title>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 106)</locus>
                        <title type="desc">Penitential Psalms</title>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 119)</locus>
                        <title type="desc">Litany</title>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 126)</locus>
                        <title type="desc">Office of the Dead</title>
                        <rubric>Officium Mortuorum</rubric>
                     </msItem>
                     
                     <msItem>
                        <note>Added by a North Italian scribe of the 15th century:</note>
                     <msItem>
                        <locus>(fol. 158)</locus>
                        <title type="desc">
                           Votive Office of the Blessed Sacrament
                        </title>
                        <rubric>Officium sacramenti Corporis et Sanguinis Christi</rubric>
                        <incipit>Panis quem ego</incipit>
                        <note>Said to have been compiled in 1339</note>
                        <note>Imperfect</note>
                     </msItem>
                  </msItem>
                     <textLang mainLang="la" otherLangs="frm">Latin and Middle French</textLang>
