               <history>
                  <origin>
                     <origDate calendar="Gregorian" notAfter="1410" notBefore="1400">15th century, beginning</origDate>
                     <origPlace>
                        <country key="place_1000070">France</country>, <region key="place_7024267">Brittany</region>, <placeName key="place_7008262">Quimper</placeName>, 
                     </origPlace>
                  </origin>
                  
                  <provenance>The occurrence of St Corentin of Quimper in gold in the Calendar points to Brittany, but at some point after 1471 
                     the manuscript migrated to <placeName>Asti</placeName> in Italy where the textual and decorative additions were introduced</provenance>
                  
                  <!-- Add authority record -->                  
                  
                  <provenance>
                     Several of the later additions point to the Carthusians of Asti, as does the addition of two feasts of St Secundus to the Calendar (31 March, 30 August) 
                  </provenance>
                  
                  <provenance><persName key="person_2384880" role="fmo">Matteo Luigi Canonici (1727– <hi rend="italic">c</hi>. 1806)</persName></provenance>
                  <provenance notAfter="1807" resp="#SC">Following Canonici's death, the collection passed to his brother, <persName key="person_446" role="fmo">Giuseppe Canonici</persName>, and 
                     then to Canonici's nephew, <persName role="fmo" key="person_431">Giovanni Perissinotti</persName>, in 1807 following Giuseppe Canonici's death</provenance>
                  <acquisition when="1817">Bought by the Bodleian Library in 1817 from Giovanni Perissinotti. On the purchase, see <ref target="https://digital.bodleian.ox.ac.uk/collections/canonici/">Digital Bodleian</ref></acquisition>
                  
               </history>
