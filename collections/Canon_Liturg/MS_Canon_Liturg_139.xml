               <msContents>
                  <msItem class="#liturgica" n="1" xml:id="MS_Canon_Liturg_139-item1"><locus from="1r" to="228v" type="inferred"/>
                     <title key="work_10565" type="desc">Book of Hours, Use of Rome</title>
                     
                     <msItem>
                        <locus>(fol. 1r)</locus>
                        <title type="desc">Calendar</title>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 13d)</locus>
                        <title type="desc">Office of the Virgin</title>
                        <rubric>Incipit offitium beate marie uirginis <sic>secunndum</sic> consuetudinem romane curie</rubric>
                        <incipit>Domine labia mea aperies</incipit>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 85r)</locus>
                        <title type="desc">Penitential Psalms</title>
                        <rubric>Incipit septem psalmi penitentiales antiphona</rubric>
                        <incipit><sic>DDomine</sic> ne i<ex>n</ex> furore tuo arguas me. neq<ex>ue</ex> i<ex>n</ex> ira tua corripias me</incipit>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 96v)</locus>
                        <title type="desc">Litany</title>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 107r)</locus>
                        <title type="desc">Office of the Dead</title>
                        <rubric>Offitium Mortuorum</rubric>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 154r)</locus>
                        <title type="desc">Office of the Cross</title>
                        <rubric>Offititium sanctissime Crucis</rubric>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 158r)</locus>
                        <title type="desc">Office of the Holy Ghost</title>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 165r)</locus>
                        <title type="desc">Hore canonice b. Bernardi de nomine Ihesu</title>
                        <rubric>... Hore canonice beati Bernardi de nomine Yhesu...</rubric>
                        <incipit>Iocundum sit yhesu eloquium meum... Dulcis yesus memoria</incipit>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 180v)</locus>
                        <title type="desc">Office of the Passion</title>
                        <rubric>Offitium sanctissime Passionis... Christi</rubric>
                        <incipit>Regem crucifixum dominum</incipit>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 205r)</locus>
                        <title type="desc">Mass of the Virgin for Advent (Rorate) with Commemorations</title>
                        <rubric>Missa beate Marie</rubric>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 217r)</locus>
                        <title type="desc">Proses</title>
                        <rubric>Quedam laus deuotissima de sancta Maria</rubric>
                        <incipit>Aue dulcis ave pia; iuste iudex ihesu christe</incipit>
                     </msItem>
                     
                     <msItem>
                        <locus>(fol. 223v)</locus>
                        <title type="desc">Quicumque and psalm 'Qui habitat'</title>
                     </msItem>
                     
