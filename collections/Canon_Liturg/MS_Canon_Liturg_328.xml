                  <decoDesc resp="#PA">
                     <summary><ref target="https://catalog.hathitrust.org/Record/000468709">Pächt and Alexander</ref> ii. 679, Pl. LXVI (<ref target="https://babel.hathitrust.org/cgi/pt?id=uiug.30112018715075&amp;seq=248">fol. 24v. Initial 'D'. The Three Magi</ref>).
                        The illumination is by an artist known as the <persName key="person_26856190" role="art">Maestro del Messale Barbo</persName>, named after Padua, Biblioteca del Seminario MS. 355, missal with the arms of Barbo (<ref target="https://www.zotero.org/groups/434020/bodleian_library_western_medieval_manuscripts_bibliography/search/Dizionario%20biografico%20dei%20miniatori%20italiani%3A%20secoli%20IX-XVI/titleCreatorYear/items/NVRG655A/item-list">Bollati, 2004</ref>). 
                        The work of this artist is found in other Bodleian manuscripts produced  in Brescia or Padua in the third quarter of the 15th century, including <ref target="https://medieval.bodleian.ox.ac.uk/catalog/manuscript_3410">MS. Canon. Misc. 382</ref>, 
                        <ref target="https://medieval.bodleian.ox.ac.uk/catalog/manuscript_6440">MS. Lat. liturg. a. 2</ref> and <ref target="https://medieval.bodleian.ox.ac.uk/catalog/manuscript_6441">MS. Lat. liturg. a. 3</ref>                           
                     </summary>
                     <decoNote type="border">Fine borders</decoNote>
                     <decoNote type="histInit">Fine historiated initials</decoNote>
                     <decoNote type="decInit">Fine other initials</decoNote>
                  </decoDesc>
                  
               </physDesc>
               <history>
                  <origin>
                     <origDate calendar="Gregorian" notAfter="1475" notBefore="1450">15th century, third quarter (1464 ? : on a flyleaf on fol. 244: '1464 co[mpletum ?]')</origDate>
                     <origPlace cert="low">
                        <country key="place_1000080">Italy</country>, <settlement key="place_7005764">Brescia</settlement> or <settlement key="place_7003085">Padua</settlement> (?)<!--ORIGINAL: Italian, Brescia or Padua (?)--></origPlace>
                  </origin>
                  
                  <provenance>St Antony of Padua is specially honoured in the calendar</provenance>
                  
                  <provenance>With the arms of Barbo</provenance>
                  
                  <provenance>Decorated by <persName key="person_26856190" role="art">Maestro del Messale Barbo</persName> whose work is found in manuscripts from Brescia, Padua and elsewhere,
                     dating from the third quarter of the 15th century. </provenance>
                  
                  <provenance>Fols iii and 243v: <persName role="fmo">'B. Suriano D'</persName> (late 15th century?). Fol. 1: 'Surianorum'</provenance>
                  
                  <!-- Add authority record -->                  

                  <provenance>Fol. 244: 16th-century scribblings with the name 'Juno Lucina'</provenance>
                  
                  <provenance><persName key="person_2384880" role="fmo">Matteo Luigi Canonici (1727– <hi rend="italic">c</hi>. 1806)</persName></provenance>
                  <provenance notAfter="1807" resp="#SC">Following Canonici's death, the collection passed to his brother, <persName key="person_446" role="fmo">Giuseppe Canonici</persName>, and 
                     then to Canonici's nephew, <persName role="fmo" key="person_431">Giovanni Perissinotti</persName>, in 1807 following Giuseppe Canonici's death</provenance>
                  <acquisition when="1817">Bought by the Bodleian Library in 1817 from Giovanni Perissinotti. On the purchase, see <ref target="https://digital.bodleian.ox.ac.uk/collections/canonici/">Digital Bodleian</ref></acquisition>
                  
               </history>
