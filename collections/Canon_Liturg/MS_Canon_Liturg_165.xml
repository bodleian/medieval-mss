               <history>
                  <origin>
                     <origDate calendar="Gregorian" notAfter="1475" notBefore="1450">15th century, third quarter</origDate>
                     <origPlace>
                        <country key="place_1000080">Italy</country>, <settlement key="place_7005868">Cremona</settlement>
                        <!--ORIGINAL: Italian, Cremona-->
                     </origPlace>
                  </origin>
                  
                  <provenance>The occurrence of Gulielmus (de Mala Valle) in red on 10th February in the Calendar, and of the translation 
                     of St Zeno in red on 21st May in the Calendar and in the Litany, indicate that the manuscript was used in a Wilhelmine house in the second half of the 15th century in 
                     or near <placeName key="place_7003262">Verona</placeName> (?) after it had become Augustinian
                  </provenance>
                  <provenance>Fol. 7: 'Domus sancte Marie de Gaza' (?) C. A.' ('Canonicorum Augustinensium' [?]) (16th century)</provenance>
                  
                  <provenance><persName key="person_2384880" role="fmo">Matteo Luigi Canonici (1727– <hi rend="italic">c</hi>. 1806)</persName></provenance>
                  <provenance notAfter="1807" resp="#SC">Following Canonici's death, the collection passed to his brother, <persName key="person_446" role="fmo">Giuseppe Canonici</persName>, and 
                     then to Canonici's nephew, <persName role="fmo" key="person_431">Giovanni Perissinotti</persName>, in 1807 following Giuseppe Canonici's death</provenance>
                  <acquisition when="1817">Bought by the Bodleian Library in 1817 from Giovanni Perissinotti. On the purchase, see <ref target="https://digital.bodleian.ox.ac.uk/collections/canonici/">Digital Bodleian</ref></acquisition>
                  
               </history>
