               <msContents>
                  
                  <msItem class="#liturgica" n="1" xml:id="MS_Canon_Liturg_330-item1">
                     <title key="work_10565" type="desc">Book of Hours, Use of Rome</title>
                        
                        <msItem>
                           <locus from="1">(fol. 1)</locus>
                           <title type="desc">Matins and Lauds of the Virgin</title>
                           <rubric>Incipit Matutinus Virginis Marie</rubric>
                           <note>Some rubrics in Italian</note>
                        </msItem>
                        
                        <msItem>
                           <locus from="29c">(fol. 29c)</locus>
                           <title type="desc">Penitential Psalms</title>
                           <note>With the litany (fol. 39)</note>
                        </msItem>
                           
                           <msItem>
                              <locus from="39">(fol. 39)</locus>
                              <title type="desc">Litany</title>
                           </msItem>
                        
                        <msItem>
                           <locus from="46v">(fol. 46v)</locus>
                           <title type="desc">Commemorations of the Virgin</title>
                           <note>Includes commemorations of St John the Baptist, St Nicholas and St Jerome</note>
                        </msItem>
                        
                        <msItem>
                           <locus from="49">(fol. 49)</locus>
                           <title type="desc">Nocturn of the Office of the Dead</title>
                           <rubric>Vigilia Mortuorum</rubric>
                        </msItem>
                        
                        <msItem>
                           <locus from="57v">(fol. 57v)</locus>
                           <title type="desc">Hymns in honour of the Holy Ghost</title>
                           <note>Also includes hymns for Corpus Christi, an apostle and a confessor</note>
                        </msItem>
                        
                        <msItem>
                           <locus from="61">(fol. 61)</locus>
                           <title type="desc">Prime, etc., of the Lady Office</title>
                           <note>Written by another hand; includes commemorations of St Vincent (fol. 83)</note>
                        </msItem>
                        
                        <msItem>
                           <locus from="84v">(fol. 84v)</locus>
                           <title type="desc">Commemoration of St Ignatius and prayer</title>
                           <note>Prayer: Crux domini sit mecum, introduced by an Italian rubric; added by a third hand</note>
                        </msItem>
                     
                     <textLang mainLang="la">Latin</textLang>
                  </msItem>
                  
