               <history>
                  <origin>
                     <origDate calendar="Gregorian" notAfter="1410" notBefore="1400">15th century, beginning</origDate>
                     <origPlace cert="low">
                        <country key="place_1000080">Italy</country>, <settlement key="place_7004847">Bologna</settlement> (?)<!--ORIGINAL: Italian, Bologna (?)--></origPlace>
                  </origin>
                  
                  <provenance>Fol. 26v, in the Collect: 'Satisfaciat... virginis Marie et sanctissimi confessoris atque pontificis tui (Ludovici atque) 
                        patris nostri (Augustini)'; the text in brackets is added by a later hand, and the second entry is written over the name 'Ludovici'
                  </provenance>
                  
                  <provenance>
                     Fol.58: 'Salvum fac domine servum tuum (A) patriarcham nostrum'. The 'A', written over an erased capital, stands for 
                     <persName>Andrea Bondimerio, Patriarch of Venice (1460-1464)</persName>
                     
                  <!-- Add authority record -->                  

                  </provenance>
                  
                  <provenance>On the inside of the back cover:'Liber iste est dominarum Sancti Ludovici. ad laudem Domini Yhesu eiusque matris' (Franciscans? 15th century).
                  </provenance>
                  
                  <provenance>Contemporary <hi rend="italic">ex libris</hi> of the nuns of <orgName role="fmo" key="org_117">‘nuns of St. Louis’ [of Toulouse], perhaps at Sant’Alvise, Venice</orgName>, 
                     on the pastedown</provenance>

                  <provenance><persName key="person_2384880" role="fmo">Matteo Luigi Canonici (1727– <hi rend="italic">c</hi>. 1806)</persName></provenance>
                  <provenance notAfter="1807" resp="#SC">Following Canonici's death, the collection passed to his brother, <persName key="person_446" role="fmo">Giuseppe Canonici</persName>, and 
                     then to Canonici's nephew, <persName role="fmo" key="person_431">Giovanni Perissinotti</persName>, in 1807 following Giuseppe Canonici's death</provenance>
                  <acquisition when="1817">Bought by the Bodleian Library in 1817 from Giovanni Perissinotti. On the purchase, see <ref target="https://digital.bodleian.ox.ac.uk/collections/canonici/">Digital Bodleian</ref></acquisition>
                  
               </history>
