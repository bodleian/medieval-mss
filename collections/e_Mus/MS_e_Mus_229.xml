                  <msItem class="#liturgica" n="2" xml:id="MS_e_Mus_229-item2">
                     <locus>(fol. 13r)</locus>
                     <title>Gospel pericopes (‘Missus est angelus’)</title>
                     <textLang mainLang="la">Latin</textLang>
                     <incipit>Missus est angelus Gabriel…</incipit>
                  </msItem>
                  <msItem class="#documenta #legalia" n="3" xml:id="MS_e_Mus_229-item3">
                     <locus>(fols 14r–38v)</locus>
                     <title key="work_11419">Customs of the Stews in the <orgName key="org_123537181">Bishop of Winchester</orgName>'s liberty in <placeName key="place_7011786">Southwark</placeName></title>
                     <textLang mainLang="enm" otherLangs="la">Middle English and Latin</textLang>
                     <note>Written for <persName key="person_1264" role="pat">William Corum</persName>, steward, 1461–1485.</note>
                     <incipit>This act … was made … in the parliament holden atte Westminster…</incipit>
                     <explicit>… the ordinaunces made be xii men at the gret lete…</explicit>
                  </msItem>
                  <msItem class="#documenta" n="4" xml:id="MS_e_Mus_229-item4">
                     <locus>(fols 17–18, 36–37)</locus>
                     <title>Memoranda</title>
                     <textLang mainLang="enm">Middle English</textLang>
                     <note>Includes note of a royal writ (10 February, Edward IV) and memorandum beginning <q>Deliveryd on Monday next after Blak Monday</q>. Leaves excised.</note>
                  </msItem>
