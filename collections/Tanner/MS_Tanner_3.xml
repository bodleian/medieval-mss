               <msContents>
                  <msItem class="#documenta" n="1" xml:id="MS_Tanner_3-item1">
                     <locus from="1r">(fol. 1r)</locus>
                     <title key="work_12752" type="desc">Papal letter of <persName key="person_307158035">Alexandri III</persName> to bishop <persName key="person_295934635">Roger of Worcester</persName>, 16 March 1167</title>
                     <incipit>Etsi a sacris canonibus alienum vel illicitum videatur quod aliquis episcopus in alterius diocesis ecclesiis quenquam instituere debeat</incipit>
                     <note>Added, 12th century, third quarter, on originally blank space. Fol. 1v contains a full page miniature (see Decoration)</note>
                     <listBibl><bibl>pr. H. M. Bannister, 'Bishop Roger of Worcester and the Church of Keynsham, with a List of Vestments and Books Possibly Belonging to Worcester', <title>English Historical Review</title>, 32/127 (Jul., 1917), pp. 387-393 at 387-8. </bibl></listBibl>
                     <textLang mainLang="la">Latin</textLang>
                  </msItem>
                  <msItem n="2" xml:id="MS_Tanner_3-item2">
                     <locus>(fols. 2r-189r)</locus>
                     <author key="person_100184667">Gregory the Great</author>
                     <title key="work_1863">Dialogi</title>
                     <rubric>Dialogorum Gregorii papae urbis Romæ libri numero iiii. de miraculis patrum Italicorum</rubric>
                     <finalRubric>Explicit liber dialogorum sanctissimi Gregorii papae urbis Romæ</finalRubric>
                     <textLang mainLang="la">Latin</textLang>
                  </msItem>
                  <msItem n="3" xml:id="MS_Tanner_3-item3">
                     <locus>(fols. 189v-190r) </locus><title type="desc">Booklist</title>
                     <note>Added list of school-books, late 11th or early 12th century, later extended to include service books and (fol. 190r) a list of vestments; perhaps, but not certainly, from Worcester, where the book seems to have been later in the twelfth century.</note>
                     <listBibl><bibl>Most recently edited <title>English Benedictine Libraries: The Shorter Catalogues</title>, CBMLC 4, B115</bibl></listBibl>
                     <textLang mainLang="la">Latin</textLang>
                  </msItem>
                  <msItem n="4" xml:id="MS_Tanner_3-item4">
                     <locus>(fol. 190r-v)</locus>
                     <title type="desc">Hymn 'Plausu chorus laetabundo', with notation</title>
                     <note>Added, 13th (?) century</note>
                     <listBibl><bibl><ref target="https://cantusindex.org/id/ah55006">Cantus Index ah55006</ref></bibl></listBibl>
                     <textLang mainLang="la">Latin</textLang></msItem>
                  <msItem n="5" xml:id="MS_Tanner_3-item5">
                     <locus>(fol. 191r)</locus>
                     <title type="desc">Note in French on the human body (added c. 1300): “Le noumbre des os de homme deus cent et dyt et seet, de veynes treys cens et lxv, dens, quant homme eyt de age, trent dens. Memorye al ceruel, entente al frount, ire al feel, auaryce eyn gyser, amour al queor, aleyne al pomoun, leese eyn lespen, penser eyn queor, sang al cors, la esperaunce al alme, la pensee al spyryt, le queor eyn la pensee, syaunce eyn queor, a Jesu Crist[?] eyn syaunce.”</title> <textLang mainLang="xno">Anglo-Norman</textLang>
                  </msItem>
                 
                  
                  
